{
  // ==================================================
  // Search Configuration
  // ==================================================
  "search_settings": {
    "search_days": 1,
    "max_results": 1000,
    "max_results_per_source": {}
  },

  // ==================================================
  // Data Source Configuration
  // ==================================================
  "data_sources": {
    "enabled": [
      "arxiv",
      "prl",
      "pra",
      "prb",
      "prc",
      "prd",
      "pre",
      "prx",
      "prxq",
      "rmp",
      "nature",
      "nature_physics",
      "nature_communications",
      "science",
      "science_advances",
      "npj_quantum_information",
      "quantum",
      "new_journal_of_physics"
    ],
    "journals": [],
    "reports_by_source": true
  },

  // ==================================================
  // ArXiv Target Domain Configuration
  // ==================================================
  "target_domains": {
    "domains": [
      "cs.AI",
      "cs.CL",
      "cs.CV",
      "cs.LG",
      "cs.SE",
      "stat.ML"
    ]
  },

  // ==================================================
  // Keyword Configuration
  // ==================================================
  "keywords": {
    "primary_keywords": {
      "weight": 1.0,
      "keywords": [
        "deep learning theory",
        "mechanistic interpretability",
        "large language model",
        "large multi-modal model",
        "vision-language model",
        "embodied intelligence",
        "LLMs on edge",
        "deployment of LLMs",
        "efficiency computation of LLMs",
        "AI agent",
        "agent harness",
        "AI safety"
      ]
    },
    "enable_reference_extraction": false,
    "reference_keywords_config": {
      "max_keywords": 10,
      "similarity_threshold": 0.75,
      "weight_distribution": {
        "high_importance": {
          "weight": 1.0,
          "count": 3
        },
        "medium_importance": {
          "weight": 0.2,
          "count": 5
        },
        "low_importance": {
          "weight": 0.1,
          "count": 2
        }
      }
    },
    "research_context": "My primary research interests lie at the intersection of Computer Vision and Deep Learning Theory. Currently, I am focused on the following pillars:\n(1) Explainable AI (XAI):\na) Black-box XAI: Axiomatic interpretation & Neural visualization.\nb) White-box XAI: Concept alignment & White-box architecture design.\n(2) Neural Network Theory:\na) Optimization: Efficient optimization strategies & Convergence analysis.\nb) Inductive Bias: Frequency bias exploration & Piece-wise linear modeling.\n(3) Large Multimodal Models:\na) Visual tokenizers & Native multimodal architectures.\nb) Efficient VLM training/inference.\nc) Multi Agents / OpenClaw.\nd) Safety alignment & Model interpretability."
  },

  // ==================================================
  // Scoring Configuration
  // ==================================================
  "scoring_settings": {
    "keyword_relevance_score": {
      "max_score_per_keyword": 10
    },
    "author_bonus": {
      "enabled": true,
      "expert_authors": [
        "Kaiming He",
        "Jie Tang"
      ],
      "bonus_points": 5.0
    },
    "passing_score_formula": {
      "base_score": 5.0,
      "weight_coefficient": 2.0
    },
    "include_all_in_report": true
  },

  // ==================================================
  // Path Configuration
  // ==================================================
  "paths": {
    "data_dir": "data",
    "reference_pdfs": "data/reference_pdfs",
    "reports": "data/reports",
    "downloaded_pdfs": "data/downloaded_pdfs",
    "history_dir": "data/history"
  },

  // ==================================================
  // Keyword Trend Tracking Configuration
  // ==================================================
  "keyword_tracker": {
    "enabled": true,
    "database": {
      "path": "data/keywords/keywords.db"
    },
    "normalization": {
      "enabled": true,
      "batch_size": 25
    },
    "trend_view": {
      "default_days": 30
    },
    "charts": {
      "bar_chart": {
        "top_n": 15
      },
      "trend_chart": {
        "top_n": 5
      }
    },
    "report": {
      "enabled": true,
      "frequency": "weekly"
    }
  },

  // ==================================================
  // Notification Configuration
  // ==================================================
  "notifications": {
    "enabled": true,
    "on_success": true,
    "on_failure": true,
    "attach_reports": true,
    "top_n": 10,
    "channels": {
      "email": {
        "enabled": true
      },
      "wechat_work": {
        "enabled": false
      },
      "dingtalk": {
        "enabled": false
      },
      "telegram": {
        "enabled": false
      },
      "slack": {
        "enabled": false
      },
      "generic_webhook": {
        "enabled": false
      }
    }
  },

  // ==================================================
  // Retry Configuration
  // ==================================================
  "retry": {
    "max_attempts": 3,
    "min_wait": 2,
    "max_wait": 30
  },

  // ==================================================
  // Logging Configuration
  // ==================================================
  "logging": {
    "rotation_type": "time",
    "keep_days": 30
  },

  // ==================================================
  // Concurrency Configuration
  // ==================================================
  "concurrency": {
    "enabled": true,
    "workers": 5
  },

  // ==================================================
  // PDF Parser Configuration
  // ==================================================
  "pdf_parser": {
    "mode": "mineru",
    "mineru_model_version": "pipeline",
    "poll_interval": 3,
    "poll_timeout": 300
  },

  // ==================================================
  // Report Configuration
  // ==================================================
  "report_settings": {
    "enable_html_report": true
  },

  // ==================================================
  // Auto-update Configuration
  // ==================================================
  "auto_update": {
    "enabled": true
  },

  // ==================================================
  // Token Tracking Configuration
  // ==================================================
  "token_tracking": {
    "enabled": true
  },

  // ==================================================
  // Trend Research Mode Configuration
  // ==================================================
  "trend_research": {
    "default_date_range_days": 365,
    "max_results": 200,
    "sort_order": "ascending",
    "report_position": "end",
    "generate_tldr": true,
    "tldr_batch_size": 10,
    "output_formats": [
      "markdown",
      "html"
    ],
    "enabled_skills": [
      "comprehensive_analysis"
    ]
  }
}
